// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // Remova a linha 'url = env("DATABASE_URL")' daqui
}

model Customer {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255) // Agora com 'String'
  email     String   @unique
  phone     String?
  cnpj      String   @unique
  address   String
  city      String
  createdAt DateTime @default(now())
}